<Window x:Class="LumineFuck.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LumineFuck.ViewModels"
        xmlns:conv="clr-namespace:LumineFuck.Converters"
        Title="LumineFuck Firewall"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Converters -->
        <conv:StringToColorConverter x:Key="StringToColor"/>
        
        <!-- Dark theme styles -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#74A8F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="#F38BA8"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="#585B70"
                                    CornerRadius="14"
                                    Width="56" Height="28"/>
                            <Border x:Name="Thumb"
                                    Background="#CDD6F4"
                                    CornerRadius="11"
                                    Width="22" Height="22"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#A6E3A1"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="4,4,4,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="🛡️ LumineFuck Firewall"
                               FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding StatusColor, Converter={StaticResource StringToColor}}"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="14" Foreground="#A6ADC8"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{DynamicResource Str_Protection}" VerticalAlignment="Center"
                               FontSize="14" Foreground="#A6ADC8" Margin="0,0,12,0"/>
                    <ToggleButton Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding AppVersion}"
                           VerticalAlignment="Center" Foreground="#585B70" FontSize="12"/>
            </Grid>
        </Border>

        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Str_BlockedIPs}" FontSize="12" Foreground="#A6ADC8"/>
                    <TextBlock Text="{Binding BlockedCount}" FontSize="32" FontWeight="Bold" Foreground="#F38BA8"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Str_ScannedIPs}" FontSize="12" Foreground="#A6ADC8"/>
                    <TextBlock Text="{Binding ScannedCount}" FontSize="32" FontWeight="Bold" Foreground="#89B4FA"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Str_BlockedDomains}" FontSize="12" Foreground="#A6ADC8"/>
                    <TextBlock Text="{Binding DomainCount}" FontSize="32" FontWeight="Bold" Foreground="#F9E2AF"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content: Blocked Log + Activity Log tabs -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="4,0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#A6ADC8"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder" Background="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0,0,0,2"
                                        Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#89B4FA"/>
                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Blocked Connections Tab -->
            <TabItem Header="{DynamicResource Str_Tab_Blocked}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <DataGrid ItemsSource="{Binding BlockedEntries}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              Foreground="#CDD6F4"
                              BorderThickness="0"
                              RowBackground="#313244"
                              AlternatingRowBackground="#3B3D50"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              FontSize="13">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#BAC2DE"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_Time}" Binding="{Binding TimestampString}" Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_IPAddress}" Binding="{Binding IpAddressString}" Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_Hostname}" Binding="{Binding Hostname}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_MatchedDomain}" Binding="{Binding MatchedDomain}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Connection Log Tab -->
            <TabItem Header="{DynamicResource Str_Tab_ConnLog}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <DataGrid ItemsSource="{Binding ConnectionLogEntries}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              Foreground="#CDD6F4"
                              BorderThickness="0"
                              RowBackground="#313244"
                              AlternatingRowBackground="#3B3D50"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              FontSize="13">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy IP Address"
                                          Command="{Binding PlacementTarget.DataContext.CopyConnectionIpCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Add to Block List"
                                          Command="{Binding PlacementTarget.DataContext.AddConnectionIpToBlockListCommand,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#BAC2DE"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_Time}" Binding="{Binding TimestampString}" Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_IPAddress}" Binding="{Binding IpAddressString}" Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_rDNS}" Binding="{Binding RdnsDisplay}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Str_Col_ISP}" Binding="{Binding IspDisplay}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Activity Log Tab -->
            <TabItem Header="{DynamicResource Str_Tab_Activity}">
                <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0">
                    <ListBox ItemsSource="{Binding LogEntries}"
                             Background="Transparent"
                             Foreground="#A6ADC8"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#A6ADC8"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="4,8,4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="{DynamicResource Str_Btn_Config}"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding OpenDomainManagerCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Str_Btn_ClearRules}"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ClearAllRulesCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Str_Btn_ClearLog}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearLogCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="{DynamicResource Str_Btn_Language}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleLanguageCommand}"
                            Margin="0,0,8,0"/>
                    <Button Command="{Binding TestFirewallCommand}"
                            Style="{StaticResource SecondaryButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Str_Btn_TestFW}"/>
                                <TextBlock Text=" ⏳" Visibility="{Binding IsFirewallTesting, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding UpdateVersionText}"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ApplyUpdateCommand}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                            Margin="0,0,8,0"/>
                    <ProgressBar Value="{Binding UpdateProgress}" Width="100" Height="8"
                                 Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVisibility}}"
                                 Foreground="#A6E3A1" Background="#45475A" BorderThickness="0"/>
                    <Button Content="{DynamicResource Str_Btn_CheckUpdates}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CheckForUpdatesCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
