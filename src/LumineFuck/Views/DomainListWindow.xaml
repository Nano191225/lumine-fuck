<Window x:Class="LumineFuck.Views.DomainListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_Cfg_Title}"
        Height="700" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#74A8F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="#F38BA8"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>

        <Style x:Key="SectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="ListBorder" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="EntryListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="EntryItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B3D50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- === Domain Suffixes Section === -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Str_Cfg_Domains_Header}" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="{DynamicResource Str_Cfg_Domains_Desc}"
                           Style="{StaticResource SectionDesc}"/>
            </StackPanel>

            <Border Style="{StaticResource ListBorder}" MaxHeight="160">
                <ListBox ItemsSource="{Binding Domains}"
                         SelectedItem="{Binding SelectedDomain}"
                         Style="{StaticResource EntryListBox}"
                         ItemContainerStyle="{StaticResource EntryItem}"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#313244" CornerRadius="6" Margin="0,0,8,0">
                    <TextBox Text="{Binding NewDomainText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding AddDomainCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <Button Grid.Column="1" Content="{DynamicResource Str_Cfg_Add}"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding AddDomainCommand}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="{DynamicResource Str_Cfg_Remove}"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveDomainCommand}"/>
            </Grid>

            <!-- === IP / CIDR Section === -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Str_Cfg_IPs_Header}" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="{DynamicResource Str_Cfg_IPs_Desc}"
                           Style="{StaticResource SectionDesc}"/>
            </StackPanel>

            <Border Style="{StaticResource ListBorder}" MaxHeight="160">
                <ListBox ItemsSource="{Binding BlockedIps}"
                         SelectedItem="{Binding SelectedIp}"
                         Style="{StaticResource EntryListBox}"
                         ItemContainerStyle="{StaticResource EntryItem}"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#313244" CornerRadius="6" Margin="0,0,8,0">
                    <TextBox Text="{Binding NewIpText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding AddIpCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <Button Grid.Column="1" Content="{DynamicResource Str_Cfg_Add}"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding AddIpCommand}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2" Content="{DynamicResource Str_Cfg_Remove}"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveIpCommand}"/>
            </Grid>

            <!-- === Advanced Settings Section === -->
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Str_Cfg_Advanced}" Style="{StaticResource SectionHeader}"/>
            </StackPanel>

            <Border Background="#313244" CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_Cfg_Notify_Title}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                        <TextBlock Text="{DynamicResource Str_Cfg_Notify_Desc}"
                                   FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding ShowNotifications}" VerticalAlignment="Center"
                              Margin="12,0,0,0" Width="18" Height="18"/>
                </Grid>
            </Border>

            <Border Background="#313244" CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_Cfg_BlockVpn_Title}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                        <TextBlock Text="{DynamicResource Str_Cfg_BlockVpn_Desc}"
                                   FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding BlockVpn}" VerticalAlignment="Center"
                              Margin="12,0,0,0" Width="18" Height="18"/>
                </Grid>
            </Border>

            <Border Background="#313244" CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_Cfg_Unblock_Title}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                        <TextBlock Text="{DynamicResource Str_Cfg_Unblock_Desc}"
                                   FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#45475A" CornerRadius="6" Padding="4,0" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBox Text="{Binding UnblockAfterSeconds, UpdateSourceTrigger=LostFocus}"
                                 Background="Transparent" Foreground="#CDD6F4" CaretBrush="#CDD6F4"
                                 BorderThickness="0" FontSize="14" FontWeight="Bold"
                                 Width="50" TextAlignment="Center" VerticalContentAlignment="Center"
                                 Padding="2,4"/>
                    </Border>
                </Grid>
            </Border>

            <Border Background="#313244" CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_Cfg_Delay_Title}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                        <TextBlock Text="{DynamicResource Str_Cfg_Delay_Desc}"
                                   FontSize="11" Foreground="#A6ADC8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#45475A" CornerRadius="6" Padding="4,0" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBox Text="{Binding BlockDelaySeconds, UpdateSourceTrigger=LostFocus}"
                                 Background="Transparent" Foreground="#CDD6F4" CaretBrush="#CDD6F4"
                                 BorderThickness="0" FontSize="14" FontWeight="Bold"
                                 Width="50" TextAlignment="Center" VerticalContentAlignment="Center"
                                 Padding="2,4"/>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
